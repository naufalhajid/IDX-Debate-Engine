# Copy this file to .env and replace placeholder values locally.
# Never commit .env or real credentials.

ENVIRONMENT=dev

# SQLite is the supported local database backend.
DATABASE_TYPE=sqlite
DATABASE_PATH=db/idx-fundamental.db
DATABASE_ECHO=false
DATABASE_POOL_ECHO=false
DATABASE_SETUP_DROP_TABLE=false

DATETIME_TIMEZONE=Asia/Jakarta
DATETIME_FORMAT=%Y-%m-%d %H:%M:%S

LOG_LEVEL=INFO
LOG_FILE_ACCESS_LEVEL=INFO
LOG_FILE_ERROR_LEVEL=ERROR
LOG_ACCESS_FILENAME=logs/success.log
LOG_ERROR_FILENAME=logs/error.log
LOG_APP_FILENAME=logs/app.log

# Required for real multi-agent debate runs. Leave blank for dry-run mode.
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_FLASH_MODEL=gemini-3.1-flash-lite
GEMINI_PRO_MODEL=gemini-3.1-pro

# OpenAI Codex (ChatGPT Plus / Responses API) Settings
CODEX_FLASH_MODEL=gpt-5.4-mini
CODEX_PRO_MODEL=gpt-5.5

# Optional Google Drive export settings.
GOOGLE_SERVICE_ACCOUNT={}
GOOGLE_DRIVE_EMAILS=["you@example.com"]

# Orchestrator and scoring knobs.
CANDIDATES_MAX_AGE_HOURS=48
CANDIDATES_AUTO_RERUN=true
CONVICTION_WEIGHT_CONFIDENCE=0.50
CONVICTION_WEIGHT_RR_RATIO=0.50
CONVICTION_RR_NORMALIZATION_CAP=5.0
REGIME_VOLATILITY_HIGH_THRESHOLD=0.02
REGIME_VOLATILITY_LOW_THRESHOLD=0.01
REGIME_VOLATILITY_LOOKBACK_DAYS=20
REGIME_HIGH_TOP_N=2
REGIME_HIGH_RPM_LIMIT=5
REGIME_HIGH_RR_CAP=4.0
REGIME_HIGH_MIN_CONVICTION=0.45
REGIME_LOW_TOP_N=5
REGIME_LOW_RPM_LIMIT=15
REGIME_LOW_RR_CAP=6.0
REGIME_LOW_MIN_CONVICTION=0.20
PORTFOLIO_MAX_PER_SECTOR=2
PORTFOLIO_MIN_CONVICTION=0.30
STOCKBIT_MAX_WORKERS=10
